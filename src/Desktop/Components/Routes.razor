@using System.Globalization

<Router AppAssembly="typeof(MauiProgram).Assembly"
				AdditionalAssemblies="new[] { typeof(GridironFrontOffice.UI.Pages.Home).Assembly }">
	<Found Context="routeData">
		<RouteView RouteData="routeData" DefaultLayout="typeof(GridironFrontOffice.UI.Components.Layout.MainLayout)" />
		<FocusOnNavigate RouteData="routeData" Selector="h1" />
	</Found>
	<NotFound>
		<LayoutView Layout="typeof(GridironFrontOffice.UI.Components.Layout.MainLayout)">
			<p>Sorry, there's nothing at this address.</p>
		</LayoutView>
	</NotFound>
</Router>