@using System.Globalization

<Router AppAssembly="typeof(MauiProgram).Assembly"
	AdditionalAssemblies="new[] { typeof(GridironFrontOffice.UI.Pages.Home).Assembly }">
	<Found Context="routeData">
		<RouteView RouteData="routeData" DefaultLayout="typeof(GridironFrontOffice.Desktop.Components.MainLayout)" />
		<FocusOnNavigate RouteData="routeData" Selector="h1" />
	</Found>
	<NotFound>
		<LayoutView Layout="typeof(GridironFrontOffice.Desktop.Components.MainLayout)">
			<GridironFrontOffice.UI.Pages.NotFound />
		</LayoutView>
	</NotFound>
</Router>