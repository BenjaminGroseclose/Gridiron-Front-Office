@page "/create-league"
@using GridironFrontOffice.Domain.Enums

@inject INavigationService NavigationService
@inject ILeagueWizardService LeagueWizardService

@if (_pendingOperation != null) {
	<LoadingSpinner />
} else {

<MudContainer MaxWidth="MaxWidth.Large" class="py-4">
	<MudText Typo="Typo.h4" Class="mb-6">League Setup Options</MudText>

	<MudTextField Label="League Name" Variant="Variant.Outlined" T="string" @bind-Value="LeagueName" FullWidth="true">
	</MudTextField>

	<MudGrid Spacing="3">
		<!-- Default Data Card -->
		<MudItem xs="12" sm="6" Class="mt-3">
			<MudCard Outlined="true" Style="@SelectedStyle(LeagueDataSource.Default)">
				<MudCardHeader Class="pb-2">
					<CardHeaderContent>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
							<MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Primary" />
							<MudText Typo="Typo.h6" Class="mb-0">Use Default Data</MudText>
						</MudStack>
					</CardHeaderContent>
				</MudCardHeader>

				<MudCardContent Style="height: 275px;">
					<MudText Class="mb-4">
						Start your league with pre-configured default data. This option provides:
					</MudText>

					<MudStack Spacing="2" Class="mb-4">
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
							<MudText>Ready-to-use league structure</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
							<MudText>Standard team and conference setup</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
							<MudText>Predefined player rosters</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
							<MudText>Quick to set up and get started</MudText>
						</MudStack>
					</MudStack>

					<MudText Typo="Typo.caption">
						Ideal for testing, learning, or a standard league configuration.
					</MudText>
				</MudCardContent>

				<MudCardActions>
					<MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="() => Source = LeagueDataSource.Default">
						Default Data
					</MudButton>
				</MudCardActions>
			</MudCard>
		</MudItem>

		<!-- Custom JSON Upload Card -->
		<MudItem xs="12" sm="6" Class="mt-3">
			<MudCard Outlined="true" Style="@SelectedStyle(LeagueDataSource.JSON)">
				<MudCardHeader Class="pb-2">
					<CardHeaderContent>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
							<MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large" Color="Color.Info" />
							<MudText Typo="Typo.h6" Class="mb-0">Upload Custom JSON</MudText>
						</MudStack>
					</CardHeaderContent>
				</MudCardHeader>

				<MudCardContent Style="height: 275px;">
					<MudText Class="mb-4">
						Import your own league configuration via a custom JSON file. This option allows:
					</MudText>

					<MudStack Spacing="2" Class="mb-4">
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Info" />
							<MudText>Complete customization of league data</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Info" />
							<MudText>Support for custom teams and divisions</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Info" />
							<MudText>Import existing league configurations</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Info" />
							<MudText>Full control over initial data</MudText>
						</MudStack>
					</MudStack>

					<MudText Typo="Typo.caption">
						Perfect for migrating data or setting up with specific requirements.
					</MudText>
				</MudCardContent>

				<MudCardActions>
					<MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="() => Source = LeagueDataSource.JSON">
						Upload JSON File
					</MudButton>
				</MudCardActions>
			</MudCard>
		</MudItem>
	</MudGrid>

	<MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-6 justify-end" OnClick="NavigateToLeagueWizard"
						 Disabled="Source == null || string.IsNullOrWhiteSpace(LeagueName) || _pendingOperation != null">
		Continue to League Setup
	</MudButton>
</MudContainer>
}

@code {

	private string LeagueName { get; set; } = "My League";
	private LeagueDataSource? Source { get; set; } = null;


	private Task? _pendingOperation = null;
	private string? _errorMessage = null;

	async Task NavigateToLeagueWizard()
	{
			if (Source == null || string.IsNullOrWhiteSpace(LeagueName))
					return;

			_errorMessage = null;
			
			try
			{
					_pendingOperation = LeagueWizardService.CreateDefaultLeagueAsync(LeagueName);
					await _pendingOperation;

					var queryParams = new Dictionary<string, object>
					{
							{ "LeagueName", LeagueName },
							{ "DataSource", (int)Source! }
					};

					NavigationService.NavigateTo("/league-wizard", queryParams);
			}
			catch (Exception ex)
			{
					_errorMessage = ex.Message;
			}
			finally
			{
					_pendingOperation = null;
					await InvokeAsync(StateHasChanged);
			}
	}


	@* async Task NavigateToLeagueWizard()
	{
		if (Source == null)
		{
			return; // Should never happen since the button is disabled, but just in case
		}

		IsLoading = true;
		PendingCreateLeague = true;
		await InvokeAsync(StateHasChanged);
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!PendingCreateLeague)
		{
			return;
		}

		PendingCreateLeague = false;

		try
		{
			await this.LeagueWizardService.CreateDefaultLeagueAsync(this.LeagueName);

			// Pass the selected league name and data source as query parameters
			var queryParams = new Dictionary<string, object>
			{
				{ "LeagueName", LeagueName },
				{ "DataSource", (int)Source! }
			};

			NavigationService.NavigateTo("/league-wizard", queryParams);
		}
		finally
		{
			IsLoading = false;
			await InvokeAsync(StateHasChanged);
		}
	} *@

	private string SelectedStyle(LeagueDataSource option)
	{
		return Source == option ? "border: 2px solid var(--mud-palette-primary);" : string.Empty;
	}
}						