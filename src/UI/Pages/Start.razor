@page "/"
@inject INavigationService NavigationService

<div class="flex flex-col items-center justify-center min-h-screen p-6">
	<div class="flex items-center gap-4 mb-6">
		<img src="img/logo.svg" alt="Gridiron Front Office" class="w-24 h-24" />
		<h1 class="text-4xl font-bold text-primary">Gridiron Front Office</h1>
	</div>

	<p class="text-xl text-muted text-center max-w-[650px] mb-8">
		Command your franchise with precision analytics and high-stakes executive decision-making.
	</p>

	<div class="flex flex-col gap-3 items-center">
		<AppButton Variant="outlined" Color="primary" OnClick="@(() => NavigateTo("/create-league"))" Style="width: 200px;">
			Create
		</AppButton>
		<AppButton Variant="outlined" Color="secondary" OnClick="OpenLoadDialog" Style="width: 200px;">
			Load
		</AppButton>
		<AppButton Variant="outlined" Color="secondary" OnClick="@(() => NavigateTo("/settings"))" Style="width: 200px;">
			Settings
		</AppButton>
		<AppButton Variant="outlined" Color="error" Style="width: 200px;">
			Quit
		</AppButton>
	</div>
</div>

@if (_showLoadDialog)
{
	<LoadLeagueDialog OnClose="() => _showLoadDialog = false" />
}

@code {
	private bool _showLoadDialog;

	void NavigateTo(string route)
	{
		NavigationService.NavigateTo(route);
	}

	void OpenLoadDialog()
	{
		_showLoadDialog = true;
	}
}