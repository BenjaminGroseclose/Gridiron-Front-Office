@page "/create-league"
@using GridironFrontOffice.Domain.Enums

@inject INavigationService NavigationService
@inject ILeagueWizardService LeagueWizardService

<div class="p-6 max-w-4xl mx-auto">
	<div class="flex items-center justify-between mb-6">
		<h2 class="text-2xl font-bold text-frost">Create a New League</h2>
		<button class="text-muted hover:text-frost transition-colors p-1 rounded hover:bg-surface cursor-pointer"
				@onclick="NavigateToStart">
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>
	</div>

	@if (!string.IsNullOrEmpty(_errorMessage))
	{
		<AppAlert Severity="error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => _errorMessage = null">
			@_errorMessage
		</AppAlert>
	}

	<AppStepper @ref="_stepper" Steps="@_stepTitles" @bind-ActiveIndex="_activeStep"
				@bind-IsCompleted="_isCompleted" OnBeforeNext="HandleBeforeNext" HideNavigation="@_isLoading">

		<ChildContent>
			@if (_activeStep == 0)
			{
				@* Step 1: League Info & Data Source *@
				@if (_isLoading)
				{
					<div class="flex flex-col items-center py-12 gap-4">
						<AppSpinner Size="lg" />
						<p class="text-muted">Initializing league data...</p>
					</div>
				}
				else
				{
					<div class="flex flex-col gap-6 p-4">
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
							<AppTextField Label="League Name" @bind-Value="_leagueName" />
							<AppNumericField TValue="int" Label="Start Year" @bind-Value="_startYear" />
						</div>

						<h3 class="text-lg font-semibold text-frost mt-2">Data Source</h3>

						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
							@* Default Data Card *@
							<AppCard Outlined="true" Style="@GetSelectedStyle(LeagueDataSource.Default)">
								<AppCardHeader>
									<div class="flex items-center gap-2">
										<svg class="w-7 h-7 text-primary" fill="currentColor" viewBox="0 0 24 24">
											<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 2l5 5h-5V4zm-3 9h4v2h-4v-2zm0 4h4v2h-4v-2zm-2-4h1v2H8v-2zm0 4h1v2H8v-2z" />
										</svg>
										<span class="text-lg font-semibold">Use Default Data</span>
									</div>
								</AppCardHeader>
								<AppCardContent>
									<p class="text-muted mb-3">Start with pre-configured teams, conferences, and rosters.</p>
									<div class="flex flex-col gap-2">
										<div class="flex items-start gap-2">
											<svg class="w-4 h-4 text-success mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
											</svg>
											<span class="text-sm">Ready-to-use league structure</span>
										</div>
										<div class="flex items-start gap-2">
											<svg class="w-4 h-4 text-success mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
											</svg>
											<span class="text-sm">Standard team and conference setup</span>
										</div>
										<div class="flex items-start gap-2">
											<svg class="w-4 h-4 text-success mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
											</svg>
											<span class="text-sm">Predefined player rosters</span>
										</div>
									</div>
								</AppCardContent>
								<AppCardActions>
									<AppButton Variant="outlined" Color="primary" OnClick="() => _dataSource = LeagueDataSource.Default">
										Select Default
									</AppButton>
								</AppCardActions>
							</AppCard>

							@* JSON Upload Card *@
							<AppCard Outlined="true" Style="@GetSelectedStyle(LeagueDataSource.JSON)">
								<AppCardHeader>
									<div class="flex items-center gap-2">
										<svg class="w-7 h-7 text-info" fill="currentColor" viewBox="0 0 24 24">
											<path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z" />
										</svg>
										<span class="text-lg font-semibold">Upload Custom JSON</span>
									</div>
								</AppCardHeader>
								<AppCardContent>
									<p class="text-muted mb-3">Import your own league configuration via a JSON file.</p>
									<div class="flex flex-col gap-2">
										<div class="flex items-start gap-2">
											<svg class="w-4 h-4 text-info mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
											</svg>
											<span class="text-sm">Complete customization of league data</span>
										</div>
										<div class="flex items-start gap-2">
											<svg class="w-4 h-4 text-info mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
											</svg>
											<span class="text-sm">Support for custom teams and divisions</span>
										</div>
										<div class="flex items-start gap-2">
											<svg class="w-4 h-4 text-info mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20">
												<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
											</svg>
											<span class="text-sm">Full control over initial data</span>
										</div>
									</div>
								</AppCardContent>
								<AppCardActions>
									<AppButton Variant="outlined" Color="info" OnClick="() => _dataSource = LeagueDataSource.JSON">
										Select JSON
									</AppButton>
								</AppCardActions>
							</AppCard>
						</div>
					</div>
				}
			}
			else if (_activeStep == 1)
			{
				@* Step 2: League Settings *@
				@if (_isLoading)
				{
					<div class="flex flex-col items-center py-12 gap-4">
						<AppSpinner Size="lg" />
						<p class="text-muted">Creating league...</p>
					</div>
				}
				else
				{
					<div class="flex flex-col gap-4 p-4">
						<AppSelect TValue="int" Label="Favorite Team" @bind-Value="_selectedTeamId">
							<option value="0" disabled>-- Select a team --</option>
							@foreach (var team in _teams)
							{
								<option value="@team.ID">@team.DisplayName</option>
							}
						</AppSelect>

						<AppDivider />

						<AppNumericField TValue="int?" Label="Roster Size" @bind-Value="_rosterSize" Min="8" />
						<AppNumericField TValue="int?" Label="Practice Squad Size" @bind-Value="_practiceSquadSize" Min="8" />

						<AppCheckbox Label="Injuries Enabled" @bind-Value="_injuriesEnabled" />
						<AppCheckbox Label="Can be Fired" @bind-Value="_canBeFired" />

						<AppNumericField TValue="double?" Label="Salary Cap (Millions)" @bind-Value="_salaryCap" Min="0" />

						<AppSelect TValue="int" Label="Number of Playoff Teams" @bind-Value="_numberOfPlayoffTeams">
							@foreach (var numOfTeams in numberOfPlayoffOptions)
							{
								<option value="@numOfTeams">@numOfTeams</option>
							}
						</AppSelect>
					</div>
				}
			}
		</ChildContent>

		<CompletedContent>
			<div class="flex flex-col items-center py-12 gap-4">
				<svg class="w-16 h-16 text-success" fill="currentColor" viewBox="0 0 20 20">
					<path fill-rule="evenodd"
						  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
						  clip-rule="evenodd" />
				</svg>
				<h3 class="text-xl font-bold text-frost">League Created!</h3>
				<p class="text-muted">Your league "<strong class="text-frost">@_leagueName</strong>" has been created.</p>
				<AppButton Color="primary" OnClick="NavigateToLeague">Go to League</AppButton>
			</div>
		</CompletedContent>
	</AppStepper>
</div>

@code {
	private AppStepper _stepper = null!;
	private int _activeStep;
	private bool _isCompleted;
	private bool _isLoading;
	private string? _errorMessage;

	private List<string> _stepTitles = new() { "League Info", "League Settings" };

	// Step 1 fields
	private string _leagueName = "My League";
	private int _startYear = DateTime.Now.Year;
	private LeagueDataSource? _dataSource;

	// Step 2 fields
	private IEnumerable<Team> _teams = [];
	private int _selectedTeamId;
	private Team? _selectedTeam => _teams.FirstOrDefault(t => t.ID == _selectedTeamId);
	private int? _rosterSize = 53;
	private int? _practiceSquadSize = 8;
	private bool _injuriesEnabled = true;
	private bool _canBeFired = false;
	private double? _salaryCap = 300;
	private int _numberOfPlayoffTeams = 14;
	private int? _numOfRegularSeasonWeeks = 17;
	private int? _numOfByeWeeks = 1;

	// Options
	private int[] numberOfPlayoffOptions = new[] { 6, 8, 10, 12, 14, 16 };

	private Task HandleBeforeNext(AppStepper.StepChangeEventArgs args)
	{
		switch (args.StepIndex)
		{
			case 0:
				if (!ValidateStep1())
				{
					args.Cancel = true;
					return Task.CompletedTask;
				}
				args.Cancel = true;
				_ = SeedLeagueDataAndAdvance();
				break;

			case 1:
				if (!ValidateStep2())
				{
					args.Cancel = true;
					return Task.CompletedTask;
				}
				args.Cancel = true;
				_ = CreateLeagueAndNavigate();
				break;
		}

		return Task.CompletedTask;
	}

	private bool ValidateStep1()
	{
		if (string.IsNullOrWhiteSpace(_leagueName))
		{
			_errorMessage = "Please enter a league name.";
			return false;
		}

		if (_dataSource is null)
		{
			_errorMessage = "Please select a data source.";
			return false;
		}

		return true;
	}

	private bool ValidateStep2()
	{
		if (!_rosterSize.HasValue)
		{
			_errorMessage = "Please set a roster size.";
			return false;
		}

		if (!_practiceSquadSize.HasValue)
		{
			_errorMessage = "Please set a practice squad size.";
			return false;
		}

		if (!_salaryCap.HasValue || _salaryCap.Value <= 0)
		{
			_errorMessage = "Please set a valid salary cap.";
			return false;
		}

		if (_numberOfPlayoffTeams <= 0)
		{
			_errorMessage = "Please select the number of playoff teams.";
			return false;
		}

		if (_selectedTeam is null)
		{
			_errorMessage = "Please select a team.";
			return false;
		}

		if (!_numOfRegularSeasonWeeks.HasValue || _numOfRegularSeasonWeeks.Value <= 0)
		{
			_errorMessage = "Please set a number of regular season weeks.";
			return false;
		}

		if (!_numOfByeWeeks.HasValue || _numOfByeWeeks.Value < 0)
		{
			_errorMessage = "Please set a valid number of bye weeks.";
			return false;
		}

		return true;
	}

	private async Task SeedLeagueDataAndAdvance()
	{
		_errorMessage = null;
		_isLoading = true;
		await InvokeAsync(StateHasChanged);

		try
		{
			var leagueName = _leagueName;
			var startYear = _startYear;
			var wizardService = LeagueWizardService;
			await Task.Run(async () =>
			{
				await wizardService.CreateDefaultLeagueAsync(leagueName, startYear);
			});
			_teams = await Task.Run(async () => await wizardService.GetDefaultTeams());
		}
		catch (Exception ex)
		{
			_errorMessage = $"Failed to initialize league data: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
			await InvokeAsync(StateHasChanged);
		}

		if (string.IsNullOrEmpty(_errorMessage))
		{
			await _stepper.NextStepAsync();
		}
	}

	private async Task CreateLeagueAndNavigate()
	{
		_errorMessage = null;
		_isLoading = true;
		await InvokeAsync(StateHasChanged);

		try
		{
			var leagueSettings = new LeagueSetting
			{
				Name = _leagueName,
				DataSource = _dataSource!.Value,
				CurrentDate = new DateTime(_startYear, 2, 15),
				SeasonID = _startYear,
				InjuriesEnabled = _injuriesEnabled,
				NumOfPlayoffsTeams = _numberOfPlayoffTeams,
				CanBeFired = _canBeFired,
				NumOfRegularSeasonWeeks = _numOfRegularSeasonWeeks!.Value,
				NumOfByeWeeks = _numOfByeWeeks!.Value,
				RosterSize = _rosterSize!.Value,
				PracticeSquadSize = _practiceSquadSize!.Value,
				SalaryCap = _salaryCap!.Value * 1_000_000
			};

			var teamId = _selectedTeam?.ID;
			var wizardService = LeagueWizardService;
			await Task.Run(async () =>
			{
				await wizardService.CreateLeagueAsync(leagueSettings, teamId);
			});
			NavigationService.NavigateTo($"/home");
		}
		catch (Exception ex)
		{
			_errorMessage = $"Failed to create league: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
			await InvokeAsync(StateHasChanged);
		}
	}

	private void NavigateToStart()
	{
		NavigationService.NavigateTo("/");
	}

	private void NavigateToLeague()
	{
		NavigationService.NavigateTo("/league");
	}

	private string GetSelectedStyle(LeagueDataSource option)
	{
		return _dataSource == option ? "border-color: #2563EB; border-width: 2px;" : string.Empty;
	}
}
