<span class="@ComputedClass">
	@ChildContent
</span>

@code {
	[Parameter] public RenderFragment? ChildContent { get; set; }
	[Parameter] public string Color { get; set; } = "primary";
	[Parameter] public string Size { get; set; } = "md";
	[Parameter] public string? Class { get; set; }

	private string ComputedClass
	{
		get
		{
			var sizeClasses = Size switch
			{
				"sm" => "px-2 py-0.5 text-xs",
				"lg" => "px-4 py-1.5 text-sm",
				_ => "px-3 py-1 text-xs"
			};

			var colorClasses = Color switch
			{
				"primary" => "bg-primary/20 text-primary",
				"secondary" => "bg-secondary/20 text-frost",
				"error" => "bg-error/20 text-error",
				"success" => "bg-success/20 text-success",
				"warning" => "bg-warning/20 text-warning",
				"info" => "bg-info/20 text-info",
				_ => "bg-primary/20 text-primary"
			};

			return $"inline-flex items-center rounded-full font-medium {sizeClasses} {colorClasses} {Class}".Trim();
		}
	}
}
