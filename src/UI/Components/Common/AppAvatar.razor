<div class="@ComputedClass" style="@ComputedStyle">
	@if (!string.IsNullOrEmpty(Text))
	{
		<span class="text-xs font-bold uppercase">@Text</span>
	}
	else
	{
		@ChildContent
	}
</div>

@code {
	[Parameter] public RenderFragment? ChildContent { get; set; }
	[Parameter] public string? Text { get; set; }
	[Parameter] public string Size { get; set; } = "md";
	[Parameter] public string? Style { get; set; }
	[Parameter] public string? Class { get; set; }
	[Parameter] public bool? Bordered { get; set; }

	private string ComputedClass
	{
		get
		{
			var sizeClasses = Size switch
			{
				"sm" => "w-8 h-8 text-xs",
				"lg" => "w-14 h-14 text-base",
				_ => "w-10 h-10 text-sm"
			};

			var borderClass = Bordered == true ? "border-1 border-white" : string.Empty;

			return $"inline-flex items-center justify-center rounded-full font-bold {sizeClasses} {borderClass} {Class}".Trim();
		}
	}

	private string ComputedStyle => Style ?? "background-color: var(--avatar-bg, #475569); color: #F1F5F9;";
}
