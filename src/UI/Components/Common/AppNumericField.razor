@typeparam TValue

<div class="@($"flex flex-col gap-1 {Class}")">
	@if (!string.IsNullOrEmpty(Label))
	{
		<label class="text-sm font-medium text-muted">@Label</label>
	}
	<input type="number" value="@Value" @onchange="HandleChange" min="@Min" max="@Max"
		   class="bg-surface border border-divider rounded-md px-3 py-2 text-frost text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary placeholder:text-muted/50 w-full" />
</div>

@code {
	[Parameter] public TValue? Value { get; set; }
	[Parameter] public EventCallback<TValue> ValueChanged { get; set; }
	[Parameter] public string? Label { get; set; }
	[Parameter] public string? Min { get; set; }
	[Parameter] public string? Max { get; set; }
	[Parameter] public string? Class { get; set; }

	private async Task HandleChange(ChangeEventArgs e)
	{
		if (e.Value is null || string.IsNullOrWhiteSpace(e.Value.ToString()))
		{
			Value = default;
			await ValueChanged.InvokeAsync(Value);
			return;
		}

		var targetType = Nullable.GetUnderlyingType(typeof(TValue)) ?? typeof(TValue);
		Value = (TValue)Convert.ChangeType(e.Value, targetType);
		await ValueChanged.InvokeAsync(Value);
	}
}
