<button class="@ComputedClass" @onclick="OnClick" disabled="@Disabled" type="@Type" style="@Style">
	@ChildContent
</button>

@code {
	[Parameter] public RenderFragment? ChildContent { get; set; }
	[Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
	[Parameter] public bool Disabled { get; set; }
	[Parameter] public string Variant { get; set; } = "filled";
	[Parameter] public string Color { get; set; } = "primary";
	[Parameter] public string? Class { get; set; }
	[Parameter] public string? Style { get; set; }
	[Parameter] public string Type { get; set; } = "button";

	private string ComputedClass
	{
		get
		{
			var baseClasses = "inline-flex items-center justify-center gap-2 px-4 py-2 rounded-md font-medium text-sm transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-canvas disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer";

			var colorClasses = Variant switch
			{
				"outlined" => Color switch
				{
					"primary" => "border border-primary text-primary hover:bg-primary/10 focus:ring-primary",
					"secondary" => "border border-secondary text-frost hover:bg-secondary/10 focus:ring-secondary",
					"error" => "border border-error text-error hover:bg-error/10 focus:ring-error",
					"success" => "border border-success text-success hover:bg-success/10 focus:ring-success",
					"warning" => "border border-warning text-warning hover:bg-warning/10 focus:ring-warning",
					"info" => "border border-info text-info hover:bg-info/10 focus:ring-info",
					_ => "border border-primary text-primary hover:bg-primary/10 focus:ring-primary"
				},
				"text" => Color switch
				{
					"primary" => "text-primary hover:bg-primary/10 focus:ring-primary",
					"secondary" => "text-frost hover:bg-secondary/10 focus:ring-secondary",
					"error" => "text-error hover:bg-error/10 focus:ring-error",
					"success" => "text-success hover:bg-success/10 focus:ring-success",
					"warning" => "text-warning hover:bg-warning/10 focus:ring-warning",
					"info" => "text-info hover:bg-info/10 focus:ring-info",
					_ => "text-primary hover:bg-primary/10 focus:ring-primary"
				},
				_ => Color switch
				{
					"primary" => "bg-primary text-white hover:bg-primary/90 focus:ring-primary",
					"secondary" => "bg-secondary text-white hover:bg-secondary/80 focus:ring-secondary",
					"error" => "bg-error text-white hover:bg-error/90 focus:ring-error",
					"success" => "bg-success text-white hover:bg-success/90 focus:ring-success",
					"warning" => "bg-warning text-black hover:bg-warning/90 focus:ring-warning",
					"info" => "bg-info text-white hover:bg-info/90 focus:ring-info",
					_ => "bg-primary text-white hover:bg-primary/90 focus:ring-primary"
				}
			};

			return $"{baseClasses} {colorClasses} {Class}".Trim();
		}
	}
}
