@inject NavigationManager NavigationService


<MudNavMenu Rounded="true" Color="Color.Tertiary" Bordered="true">
	<MudNavLink Href="home">Home</MudNavLink>
	<MudNavLink Href="roster">Roster</MudNavLink>

	<MudSpacer />
	<MudNavLink Href="settings">Settings</MudNavLink>
	<MudNavLink OnClick="ToggleExpanded"
							Icon="@(IsExpanded ? Icons.Material.Filled.MenuOpen : Icons.Material.Filled.Menu)">
	</MudNavLink>

</MudNavMenu>


@code {

	private MudTheme Theme = new MudTheme();
	private bool IsExpanded { get; set; } = false;

	private void ToggleExpanded()
	{
		IsExpanded = !IsExpanded;
	}

	private void Navigate(NavItem item)
	{
		switch (item)
		{
			case NavItem.Home:
				NavigationService.NavigateTo("/home");
				break;
			case NavItem.Roster:
				NavigationService.NavigateTo("/roster");
				break;
			case NavItem.Team:
				NavigationService.NavigateTo("/team");
				break;
			case NavItem.Schedule:
				NavigationService.NavigateTo("/schedule");
				break;
			case NavItem.Settings:
				NavigationService.NavigateTo("/settings");
				break;
		}
	}

	private enum NavItem
	{
		Home,
		Roster,
		Team,
		Schedule,
		Settings
	}
}