@inject NavigationManager NavigationService

<MudStack AlignItems="AlignItems.Center" Class="px-2"
					Style="@($"width: {width}px; transition: width 0.3s; border-right: 1px solid {Theme.PaletteDark.Divider}; height: calc(100vh - 64px);")">

	<MudNavMenu Rounded="true" Color="Color.Info">
		<MudNavLink OnClick="() => Navigate(NavItem.Home)" Icon="@Icons.Material.Filled.Home">@(IsExpanded ? "Home" : "")
		</MudNavLink>

	</MudNavMenu>

	<MudSpacer />
	<MudIconButton Icon="@Icons.Material.Filled.Expand" Color="Color.Default" OnClick="ToggleWidth" />

</MudStack>

@code {

	private MudTheme Theme = new MudTheme();
	private int width = 80;
	public bool IsExpanded => width > 80;

	private void ToggleWidth()
	{
		width = width == 80 ? 200 : 80;
	}

	private void Navigate(NavItem item)
	{
		switch (item)
		{
			case NavItem.Home:
				NavigationService.NavigateTo("/home");
				break;
			case NavItem.League:
				NavigationService.NavigateTo("/league");
				break;
			case NavItem.Team:
				NavigationService.NavigateTo("/team");
				break;
			case NavItem.Schedule:
				NavigationService.NavigateTo("/schedule");
				break;
			case NavItem.Settings:
				NavigationService.NavigateTo("/settings");
				break;
		}
	}

	private enum NavItem
	{
		Home,
		League,
		Team,
		Schedule,
		Settings
	}
}