@inject AppState AppState
@inject ITeamService TeamService

<header class="flex items-center gap-2 px-4 h-16 border-b border-divider shrink-0">
	<AppAvatar Size="md" Style="@_currentTeam?.GetTeamAvatarStyle()" Bordered="true">
		@_currentTeam?.Abbreviation
	</AppAvatar>

	<div class="flex-1"></div>

	<AppChip Color="info">@_currentSeason</AppChip>
	<span class="text-sm text-muted">@AppState.CurrentState.CurrentDateTime?.ToString("MMMM dd, yyyy")</span>
</header>

@code {
	private Team? _currentTeam;
	private int _currentSeason => AppState.CurrentState.CurrentSeason?.Year ?? 0;

	override protected async Task OnInitializedAsync()
	{
		if (AppState.CurrentState.UserTeamID.HasValue)
		{
			_currentTeam = await TeamService.GetTeam(AppState.CurrentState.UserTeamID.Value);
		}
	}
}