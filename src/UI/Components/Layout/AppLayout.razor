@inherits LayoutComponentBase
@layout MainLayout
@inject AppState AppState
@inject INavigationService NavigationService
@implements IDisposable

<div class="flex flex-col h-screen">
	<AppHeader />

	<div class="flex flex-1 overflow-hidden">
		<AppSideNav />

		<main class="flex-1 p-6 overflow-y-auto">
			@if (!string.IsNullOrEmpty(_state.Error))
			{
				<AppAlert Severity="error" ShowCloseIcon="true" CloseIconClicked="DismissError" Class="mb-4">
					@_state.Error
				</AppAlert>
			}

			@if (_state.IsLoading)
			{
				<LoadingSpinner />
			}
			else
			{
				@Body
			}
		</main>
	</div>
</div>

@code {
	private bool _drawerOpen = true;
	private AppState.StateSnapshot _state = default!;

	protected override void OnInitialized()
	{
		_state = AppState.CurrentState;
		AppState.Subscribe(OnStateChanged);
	}

	private void OnStateChanged(AppState.StateSnapshot snapshot)
	{
		_state = snapshot;
		InvokeAsync(StateHasChanged);
	}

	private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

	private void DismissError() => AppState.SetError(null);

	public void Dispose()
	{
		AppState.Unsubscribe(OnStateChanged);
	}
}
