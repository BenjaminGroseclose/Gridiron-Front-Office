@inherits LayoutComponentBase
@layout MainLayout
@inject AppState AppState
@inject INavigationService NavigationService
@implements IDisposable

<MudLayout>
	
	<AppHeader />

	<MudMainContent Class="pa-4">

		<MudStack Row="true">
			<AppSideNav />

			<div id="app-content">

				@if (!string.IsNullOrEmpty(_state.Error))
				{
					<MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="DismissError" Class="mb-4">
						@_state.Error
					</MudAlert>
				}

				@if (_state.IsLoading)
				{
					<LoadingSpinner />
				}
				else
				{
					@Body
				}
			</div>
		</MudStack>
	</MudMainContent>
</MudLayout>

@code {
	private bool _drawerOpen = true;
	private AppState.StateSnapshot _state = default!;

	protected override void OnInitialized()
	{
		_state = AppState.CurrentState;
		AppState.Subscribe(OnStateChanged);
	}

	private void OnStateChanged(AppState.StateSnapshot snapshot)
	{
		_state = snapshot;
		InvokeAsync(StateHasChanged);
	}

	private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

	private void DismissError() => AppState.SetError(null);

	public void Dispose()
	{
		AppState.Unsubscribe(OnStateChanged);
	}
}
