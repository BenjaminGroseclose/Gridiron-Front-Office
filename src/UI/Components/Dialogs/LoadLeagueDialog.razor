@using GridironFrontOffice.Persistence
@inject GameManager GameManager
@inject ILeagueWizardService LeagueWizardService
@inject INavigationService NavigationService

<AppDialog Visible="true" Title="Load League" OnClose="Cancel">
	<ChildContent>
		@if (_saveFiles.Count == 0)
		{
			<p class="text-muted py-4">No save files found.</p>
		}
		else
		{
			<AppTable TItem="SaveFileInfo" Items="_saveFiles" @bind-SelectedItem="_selectedSave">
				<HeaderContent>
					<th class="px-4 py-2 text-left w-8"></th>
					<th class="px-4 py-2 text-left">Name</th>
					<th class="px-4 py-2 text-left">Last Saved</th>
				</HeaderContent>
				<RowTemplate>
					<td class="px-4 py-2">
						<input type="radio" checked="@(_selectedSave == context)"
							   @onchange="() => OnSaveSelected(context)"
							   class="accent-primary cursor-pointer" />
					</td>
					<td class="px-4 py-2">@context.Name</td>
					<td class="px-4 py-2 text-muted">@context.LastModified.ToString("MMM dd, yyyy h:mm tt")</td>
				</RowTemplate>
			</AppTable>
		}

		@if (!string.IsNullOrEmpty(_error))
		{
			<AppAlert Severity="error" Class="mt-3">@_error</AppAlert>
		}
	</ChildContent>
	<FooterContent>
		<AppButton Variant="text" Color="secondary" OnClick="Cancel">Cancel</AppButton>
		<AppButton Color="primary" Disabled="@(_selectedSave == null || _loading)" OnClick="LoadSelected">
			@if (_loading)
			{
				<AppSpinner Size="sm" Color="frost" Class="mr-2" />
			}
			Load
		</AppButton>
	</FooterContent>
</AppDialog>

@code {
	[Parameter] public EventCallback OnClose { get; set; }

	private List<SaveFileInfo> _saveFiles = new();
	private SaveFileInfo? _selectedSave;
	private bool _loading;
	private string? _error;

	protected override void OnInitialized()
	{
		_saveFiles = GameManager.GetSaveFiles()
			.Select(f => new SaveFileInfo(f.Name, f.LastModified))
			.ToList();
	}

	private void OnSaveSelected(SaveFileInfo item)
	{
		_selectedSave = item;
		_error = null;
	}

	private async Task LoadSelected()
	{
		if (_selectedSave == null) return;

		try
		{
			_loading = true;
			_error = null;

			await LeagueWizardService.LoadLeagueAsync(_selectedSave.Name);

			await OnClose.InvokeAsync();
			NavigationService.NavigateTo("/home");
		}
		catch (Exception ex)
		{
			_error = ex.Message;
		}
		finally
		{
			_loading = false;
		}
	}

	private async Task Cancel() => await OnClose.InvokeAsync();

	private record SaveFileInfo(string Name, DateTime LastModified);
}
