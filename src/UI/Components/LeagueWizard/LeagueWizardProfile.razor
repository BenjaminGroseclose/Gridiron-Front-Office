@inject ILeagueWizardService LeagueWizardService

<MudStack Spacing="3">
	<MudText Typo="Typo.h5">Coach Profile</MudText>

	<MudDivider />

	<MudTextField T="string" Value="_coachName" Label="Coach Name" Variant="Variant.Outlined" FullWidth="true"
								ValueChanged="@((value) => { _coachName = value; UpdateLeagueSetupForm(); })" />

	<MudSelect T="string" Value="_coachExperience" Label="Coaching Experience" Variant="Variant.Outlined" FullWidth="true"
						 ValueChanged="@((value) => { _coachExperience = value; UpdateLeagueSetupForm(); })">
		@foreach (var option in _experienceOptions)
		{
			<MudSelectItem Value="@option.Value">@option.Label</MudSelectItem>
		}
	</MudSelect>

	<MudSelect T="string" Value="_coachPhilosophy" Label="Coaching Philosophy" Variant="Variant.Outlined" FullWidth="true"
						 ValueChanged="@((value) => { _coachPhilosophy = value; UpdateLeagueSetupForm(); })">
		@foreach (var option in _philosophyOptions)
		{
			<MudSelectItem Value="@option.Value">@option.Label</MudSelectItem>
		}
	</MudSelect>
</MudStack>

@code {
	private string _coachName = string.Empty;
	private string _coachExperience = string.Empty;
	private string _coachPhilosophy = string.Empty;

	private List<(string Value, string Label)> _experienceOptions = new List<(string, string)>
	{
		("Rookie", "Rookie"),
		("Intermediate", "Intermediate"),
		("Veteran", "Veteran")
	};

	private List<(string Value, string Label)> _philosophyOptions = new List<(string, string)>
	{
		("Offensive", "Offensive"),
		("Defensive", "Defensive"),
		("Balanced", "Balanced")
	};

	protected override void OnInitialized()
	{
		_coachName = LeagueWizardService.CurrentLeagueSetupForm.CoachName ?? string.Empty;
		_coachExperience = LeagueWizardService.CurrentLeagueSetupForm.CoachExperience ?? string.Empty;
		_coachPhilosophy = LeagueWizardService.CurrentLeagueSetupForm.CoachPhilosophy ?? string.Empty;
		LeagueWizardService.OnChange += UpdateState;

		base.OnInitialized();
	}

	public void Dispose()
	{
		LeagueWizardService.OnChange -= UpdateState;
	}

	void UpdateState()
	{
		_coachName = LeagueWizardService.CurrentLeagueSetupForm.CoachName ?? string.Empty;
		_coachExperience = LeagueWizardService.CurrentLeagueSetupForm.CoachExperience ?? string.Empty;
		_coachPhilosophy = LeagueWizardService.CurrentLeagueSetupForm.CoachPhilosophy ?? string.Empty;
		StateHasChanged();
	}

	void UpdateLeagueSetupForm()
	{
		LeagueWizardService.UpdateLeagueSetupForm(new Domain.Forms.LeagueSetupForm
		{
			CoachName = _coachName,
			CoachExperience = _coachExperience
		});
	}
}