@inject ILeagueWizardService LeagueWizardService
@implements IDisposable


<MudStack Spacing="3">
	<MudText Typo="Typo.h5" Class="mb-3">League Settings</MudText>

	<MudDivider />

	<MudNumericField Label="Roster Size" Variant="Variant.Outlined" T="int" @bind-Value="RosterSize" Min="8">
	</MudNumericField>


	<MudNumericField Label="Practice Squad Size" Variant="Variant.Outlined" T="int" @bind-Value="PracticeSquadSize"
									 Min="8">
	</MudNumericField>

	<MudCheckBox Label="Injuries Enabled" T="bool" @bind-Checked="InjuriesEnabled">
	</MudCheckBox>


	<MudCheckBox Label="Can be Fired" T="bool" @bind-Checked="CanBeFired">
	</MudCheckBox>

	<MudNumericField T="double" Label="Salary Cap (Millions)" Variant="Variant.Outlined" @bind-Value="SalaryCap" Min="0">
	</MudNumericField>

	<MudNumericField T="double" Label="Salary Floor (%)" Variant="Variant.Outlined" @bind-Value="SalaryCapFloor" Min="0">
	</MudNumericField>

</MudStack>

@code {

	protected override void OnInitialized()
	{
		LeagueWizardService.OnChange += UpdateState;
		base.OnInitialized();
	}

	public void Dispose()
	{
		LeagueWizardService.OnChange -= UpdateState;
	}

	private int RosterSize
	{
		get => LeagueWizardService.CurrentLeagueSetupForm.RosterSize ?? 53;
		set
		{
			var form = LeagueWizardService.CurrentLeagueSetupForm;
			form.RosterSize = value;
			LeagueWizardService.UpdateLeagueSetupForm(form);
		}
	}

	private int PracticeSquadSize
	{
		get => LeagueWizardService.CurrentLeagueSetupForm.PracticeSquadSize ?? 16;
		set
		{
			var form = LeagueWizardService.CurrentLeagueSetupForm;
			form.PracticeSquadSize = value;
			LeagueWizardService.UpdateLeagueSetupForm(form);
		}
	}

	private bool InjuriesEnabled
	{
		get => LeagueWizardService.CurrentLeagueSetupForm.InjuriesEnabled ?? false;
		set
		{
			var form = LeagueWizardService.CurrentLeagueSetupForm;
			form.InjuriesEnabled = value;
			LeagueWizardService.UpdateLeagueSetupForm(form);
		}
	}

	private bool CanBeFired
	{
		get => LeagueWizardService.CurrentLeagueSetupForm.CanBeFired ?? false;
		set
		{
			var form = LeagueWizardService.CurrentLeagueSetupForm;
			form.CanBeFired = value;
			LeagueWizardService.UpdateLeagueSetupForm(form);
		}
	}

	private double SalaryCap
	{
		get => LeagueWizardService.CurrentLeagueSetupForm.SalaryCap ?? 255.0;
		set
		{
			var form = LeagueWizardService.CurrentLeagueSetupForm;
			form.SalaryCap = value;
			LeagueWizardService.UpdateLeagueSetupForm(form);
		}
	}

	private double SalaryCapFloor
	{
		get => LeagueWizardService.CurrentLeagueSetupForm.SalaryCapFloor ?? 0.9;
		set
		{
			var form = LeagueWizardService.CurrentLeagueSetupForm;
			form.SalaryCapFloor = value;
			LeagueWizardService.UpdateLeagueSetupForm(form);
		}
	}

	private void UpdateState()
	{
		StateHasChanged();
	}
}