@inject ILeagueWizardService LeagueWizardService

<MudContainer MaxWidth="MaxWidth.Large" class="py-4">
	<MudText Typo="Typo.h4" Class="mb-6">League Setup Options</MudText>

	<MudGrid Spacing="3">
		<!-- Default Data Card -->
		<MudItem xs="12" sm="6">
			<MudCard Class="h-100">
				<MudCardHeader Class="pb-2">
					<CardHeaderContent>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
							<MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Large" Color="Color.Primary" />
							<MudText Typo="Typo.h6" Class="mb-0">Use Default Data</MudText>
						</MudStack>
					</CardHeaderContent>
				</MudCardHeader>

				<MudCardContent>
					<MudText Class="mb-4">
						Start your league with pre-configured default data. This option provides:
					</MudText>

					<MudStack Spacing="2" Class="mb-4">
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
							<MudText>Ready-to-use league structure</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
							<MudText>Standard team and conference setup</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
							<MudText>Predefined player rosters</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
							<MudText>Quick to set up and get started</MudText>
						</MudStack>
					</MudStack>

					<MudText Typo="Typo.caption">
						Ideal for testing, learning, or a standard league configuration.
					</MudText>
				</MudCardContent>

				<MudCardActions>
					<MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true">
						Use Default Data
					</MudButton>
				</MudCardActions>
			</MudCard>
		</MudItem>

		<!-- Custom JSON Upload Card -->
		<MudItem xs="12" sm="6">
			<MudCard Class="h-100">
				<MudCardHeader Class="pb-2">
					<CardHeaderContent>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
							<MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large" Color="Color.Info" />
							<MudText Typo="Typo.h6" Class="mb-0">Upload Custom JSON</MudText>
						</MudStack>
					</CardHeaderContent>
				</MudCardHeader>

				<MudCardContent>
					<MudText Class="mb-4">
						Import your own league configuration via a custom JSON file. This option allows:
					</MudText>

					<MudStack Spacing="2" Class="mb-4">
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Info" />
							<MudText>Complete customization of league data</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Info" />
							<MudText>Support for custom teams and divisions</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Info" />
							<MudText>Import existing league configurations</MudText>
						</MudStack>
						<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Start">
							<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Info" />
							<MudText>Full control over initial data</MudText>
						</MudStack>
					</MudStack>

					<MudText Typo="Typo.caption">
						Perfect for migrating data or setting up with specific requirements.
					</MudText>
				</MudCardContent>

				<MudCardActions>
					<MudButton Variant="Variant.Filled" Color="Color.Info" FullWidth="true">
						Upload JSON File
					</MudButton>
				</MudCardActions>
			</MudCard>
		</MudItem>
	</MudGrid>
</MudContainer>

