@inject ILeagueWizardService LeagueWizardService


<MudStack Spacing="3">
	<MudText Typo="Typo.h5" Class="mb-3">League Settings</MudText>

	<MudDivider />

	<MudTextField Label="League Name" Variant="Variant.Outlined" T="string" @bind-Value="_leagueName"
								@bind-Value:after="UpdateLeagueWizardService" FullWidth="true"></MudTextField>


	<MudNumericField Label="Roster Size" Variant="Variant.Outlined" T="int" @bind-Value="_rosterSize"
									 @bind-Value:after="UpdateLeagueWizardService" Min="8">
	</MudNumericField>


	<MudNumericField Label="Practice Squad Size" Variant="Variant.Outlined" T="int" @bind-Value="_practiceSquadSize"
									 @bind-Value:after="UpdateLeagueWizardService" Min="8">
	</MudNumericField>

	<MudCheckBox Label="Injuries Enabled" T="bool" @bind-Checked="_injuriesEnabled"
							 @bind-Checked:after="UpdateLeagueWizardService">
	</MudCheckBox>


	<MudCheckBox Label="Can be Fired" T="bool" @bind-Checked="_canBeFired"
							 @bind-Checked:after="UpdateLeagueWizardService">
	</MudCheckBox>

	<MudNumericField T="double" Label="Salary Cap (Millions)" Variant="Variant.Outlined" @bind-Value="_salaryCap"
									 @bind-Value:after="UpdateLeagueWizardService" Min="0">
	</MudNumericField>

	<MudNumericField T="double" Label="Salary Floor (%)" Variant="Variant.Outlined" @bind-Value="_salaryCapFloor"
									 @bind-Value:after="UpdateLeagueWizardService" Min="0">
	</MudNumericField>

</MudStack>

@code {

	// League Settings with defaults
	private string _leagueName;
	private bool _injuriesEnabled;
	private int _rosterSize;
	private int _practiceSquadSize;
	private bool _canBeFired;
	private double _salaryCap;
	private double _salaryCapFloor;

	protected override void OnInitialized()
	{
		this.UpdateLocalPropertiesFromService();
		LeagueWizardService.OnChange += UpdateState;
		base.OnInitialized();
	}

	public void Dispose()
	{
		LeagueWizardService.OnChange -= UpdateState;
	}

	void UpdateLeagueWizardService()
	{

	}

	void UpdateState()
	{
		this.UpdateLocalPropertiesFromService();
		StateHasChanged();
	}

	private void UpdateLocalPropertiesFromService()
	{
		var form = LeagueWizardService.CurrentLeagueSetupForm;
		_leagueName = form.LeagueName ?? string.Empty;
		_injuriesEnabled = form.InjuriesEnabled ?? false;
		_rosterSize = form.RosterSize ?? 53;
		_practiceSquadSize = form.PracticeSquadSize ?? 16;
		_canBeFired = form.CanBeFired ?? false;
		_salaryCap = form.SalaryCap ?? 255.0;
		_salaryCapFloor = form.SalaryCapFloor ?? 0.9;
	}
}