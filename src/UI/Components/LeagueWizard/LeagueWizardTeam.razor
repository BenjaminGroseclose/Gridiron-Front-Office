@inject ILeagueWizardService LeagueWizardService

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
	<MudStack Spacing="4">
		<!-- Header Section -->
		<MudStack Spacing="1">
			<MudText Typo="Typo.h4" Color="Color.Primary">
				<MudIcon Icon="@Icons.Material.Filled.Groups" Class="mr-2" />
				Select Your Team
			</MudText>
			<MudText Typo="Typo.body1">
				Choose the team you'll lead to victory. Players and coaching staff will be assigned after team selection.
			</MudText>
		</MudStack>

		<MudDivider />

		<MudSelect @bind-Value="_selectedTeamId" Label="Available Teams" Variant="Variant.Outlined" FullWidth="true">
			@foreach (var team in _availableTeams)
			{
				var conferenceName = GetConferenceName(team);
				var stadiumName
				<MudSelectItem T= "int?" Value = "@((int?)team.TeamID)" >
					< MudStack Row = "true" Spacing = "3" AlignItems = "AlignItems.Center" >
						@if(!string.IsNullOrEmpty(team.LogoPath))
									{
					<MudAvatar Size="Size.Medium" Image="@team.LogoPath" Alt="@team.Name" />
				}
						else
				{
					<MudAvatar Size="Size.Medium" Color="Color.Secondary" Class="mud-border-primary mud-border-solid">
						@team.Abbreviation
					</MudAvatar>
				}
				<div>
					<MudText Typo="Typo.subtitle1">@team.City @team.Name</MudText>
					<MudText Typo="Typo.caption" Color="Color.Secondary">@conferenceName</MudText>
				</div>

				<MudSpacer />

				<div>
					<MudText Typo="Typo.subtitle1">@team.City @team.Name</MudText>
					<MudText Typo="Typo.caption" Color="Color.Secondary">@conferenceName</MudText>
				</div>

			</MudStack>

		</MudSelectItem>
	}
</MudSelect>
</MudStack>
</MudContainer>


@code {
	private IEnumerable<Team> _availableTeams = Enumerable.Empty<Team>();
	private IEnumerable<Conference> _availableConferences = Enumerable.Empty<Conference>();
	private IEnumerable<Division> _availableDivisions = Enumerable.Empty<Division>();
	private IEnumerable<Stadium> _availableStadiums = Enumerable.Empty<Stadium>();
	private int? _selectedTeamId;

	protected override void OnInitialized()
	{
		_availableTeams = LeagueWizardService.GetAvailableTeams();
		_availableConferences = LeagueWizardService.GetConferences();
		_availableDivisions = LeagueWizardService.GetDivisions();
		_availableStadiums = LeagueWizardService.GetStadiums();
		_selectedTeamId = LeagueWizardService.CurrentLeagueSetupForm.SelectedTeamID;

		LeagueWizardService.OnChange += StateHasChanged;

		base.OnInitialized();
	}

	public void Dispose()
	{
		LeagueWizardService.OnChange -= StateHasChanged;
	}

	private void SelectTeam(int teamId)
	{
		_selectedTeamId = teamId;
		LeagueWizardService.UpdateSelectedTeam(teamId);
		StateHasChanged();
	}

	private string GetTeamCardClass(int teamId)
	{
		var isSelected = _selectedTeamId == teamId;
		return isSelected ? "mud-border-primary mud-border-solid" : "";
	}

	private string GetConferenceName(Team team)
	{
		var conference = _availableConferences.FirstOrDefault(c => c.ConferenceID == team.ConferenceID);
		var division = _availableDivisions.FirstOrDefault(d => d.DivisionID == team.DivisionID);
		return conference != null && division != null ? $"{conference.Abbreviation} - {division.Name}" : "N/A";
	}

	private (string stadium, string location) GetStadiumName(Team team)
	{
		var stadium = _availableStadiums.FirstOrDefault(s => s.StadiumID == team.StadiumID);
		return (stadium != null ? stadium.Name : "N/A", stadium != null ? stadium.Location : "N/A");
	}

}